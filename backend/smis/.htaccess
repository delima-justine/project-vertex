# Disable Directory Listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "^\.env|composer\.(json|lock)|package\.(json|lock)|artisan|phpunit\.xml|\.gitignore|db_esmis">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files and folders (like .git)
RewriteEngine On
RewriteRule "(^|/)\.(?!well-known/)" - [F]

# Disable Server Signature
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/

    # FIX: Pass Authorization Header to PHP (Crucial for Hostinger)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect all requests to the public/ folder
    # We prepend /api/ so it matches Laravel's routing
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php/api/$1 [L]

    # If the request is for a physical file that exists in the public/ folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
